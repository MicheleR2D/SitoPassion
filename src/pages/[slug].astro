---
// Route root-level per i singoli articoli blog: permalink_structure WP verificato e' flat
// "/%postname%/" (NON "/blog/<slug>/") - solo l'indice vive su /blog/, vedi content.config.ts
// e slug-map.js per i dettagli.
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '../layouts/BlogPostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.data.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogPostLayout post={post}>
  <Content />
</BlogPostLayout>
