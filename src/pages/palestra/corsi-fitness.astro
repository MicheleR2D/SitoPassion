---
import { getEntry, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

// URL reale gerarchico (post_parent = palestra): /palestra/corsi-fitness/, vedi slug-map.js
const page = await getEntry('pages', 'palestra/corsi-fitness');
const { Content } = await render(page);
---

<PageLayout page={page}>
  <Content />
</PageLayout>
