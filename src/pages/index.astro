---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/ui/Hero.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import CTA from '../components/ui/CTA.astro';
import PostList from '../components/blog/PostList.astro';

const PROVA_URL =
  'https://automazione.n8ndevelop.it/form/8ce36c5e-0cc4-4813-9a0f-2da2a7605fb0?source=SitoWeb&medium=Btn_Home';
const ABBONAMENTI_URL = 'https://passion.perfectgym.com/clientportal2/#/Registration';

const QUICKLINKS = [
  {
    title: 'Planning',
    body: "Oltre 250 lezioni al mese tra Rebalance, Energy, Pilates e Reformer, distribuite su più sale e studi dedicati. Consulta gli orari aggiornati in tempo reale e organizza la tua settimana di allenamento in pochi secondi.",
    href: '/orari-corsi/',
    cta: 'Scopri il planning',
    icon: 'calendar',
    image: '/images/uploads/2025/01/corso-di-step-min-1168x600-1.jpg',
  },
  {
    title: 'Abbonamenti',
    body: 'Dalla sala pesi in accesso libero ai pacchetti di Personal Training, fino alle formule Open pensate per chi si allena senza vincoli di orario. Scegli la soluzione più adatta al tuo obiettivo e al tuo budget.',
    href: ABBONAMENTI_URL,
    cta: 'Scopri gli abbonamenti',
    icon: 'dumbbell',
    image: '/images/uploads/2024/10/Palestra-11920x.jpg',
  },
  {
    title: 'Prova Open',
    body: "Vieni a scoprire di persona sala pesi, corsi fitness e studi Reformer con un accesso gratuito e senza impegno. Il nostro staff ti guida nella scelta del percorso più adatto a te fin dal primo allenamento.",
    href: PROVA_URL,
    cta: 'Prova gratis',
    icon: 'heart-arm',
    image: '/images/uploads/2024/11/MRZ01857-scaled.jpeg',
  },
];

const QUICKLINK_ICONS = {
  calendar:
    '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="8" width="30" height="34" rx="3"/><rect x="17" y="4" width="14" height="8" rx="2"/><line x1="15" y1="21" x2="33" y2="21"/><line x1="15" y1="28" x2="33" y2="28"/><line x1="15" y1="35" x2="25" y2="35"/></svg>',
  dumbbell:
    '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="20" r="5"/><circle cx="15" cy="28" r="4"/><line x1="15" y1="24" x2="31" y2="12"/><circle cx="35" cy="16" r="4"/><circle cx="40" cy="22" r="3"/></svg>',
  'heart-arm':
    '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 36c0-11 6-21 17-23-2 6 0 11 6 11"/><path d="M29 11c2-3 6-3 8 0 2-3 6-3 8 0 0 4-4 8-8 10-4-2-8-6-8-10Z"/></svg>',
};

const PROGRAMMI = [
  {
    id: 'sala-pesi',
    title: 'Sala Pesi',
    kicker: '1000 mq di sala pesi attrezzata',
    body: "Passion Fitness è costantemente aggiornata sulle ultime innovazioni nel mondo delle attrezzature per il massimo coinvolgimento muscolare. Macchinari Technogym e Panatta di ultima generazione, progettati per un allenamento all'avanguardia.",
    video: '/videos/2024/11/Sala-Pesi_Passion-Fitness.mp4',
    href: '/palestra/sala-pesi/',
    cta: 'Accedi alla Sala Pesi',
  },
  {
    id: 'corsi-fitness',
    title: 'Corsi Fitness',
    kicker: "Le sale più grandi della Tuscolana",
    body: '2 sale dedicate, corsi dalle 7:00 alle 21:30: +120h di lezioni Rebalance (Pilates, Pilates Barre, Posturale, Yoga) e +130h di lezioni Energy (Pump, Met-Con, Prepugilistica, Funzionale, Booty Pump).',
    video: '/videos/2025/02/Metcon-2.mp4',
    href: '/palestra/corsi-fitness/',
    cta: 'Accedi ai Corsi Fitness',
  },
  {
    id: 'i-love-my-trainer',
    title: 'I Love My Trainer',
    kicker: 'Un personal trainer per i tuoi obiettivi',
    body: "Con la formula I Love My Trainer, acquistando lezioni individuali con uno dei nostri PT, avrai in omaggio l'abbonamento in palestra. A partire da 65€/mese.",
    video: '/videos/2024/11/I-love-my-trainer-2.mp4',
    href: '/i-love-my-trainer/',
    cta: 'Accedi al Personal Training',
  },
  {
    id: 'pilates-reformer',
    title: 'Studio Pilates Reformer',
    kicker: "Vivi l'esperienza reformer",
    body: 'Studio Reformer per costruire basi solide, Studio Reformer+ per classi intermedie e avanzate, Studio Reformer Individuale per un percorso su misura con un trainer dedicato.',
    video: '/videos/2024/10/reformer_senza_testi.mp4',
    href: '/pilates-reformer/',
    cta: 'Accedi al Reformer',
  },
];

const FAQ = [
  {
    q: 'Quali sono gli orari di apertura della palestra?',
    a: 'Passion Fitness Tuscolana è aperta tutti i giorni, dalle 5 alle 24.',
  },
  {
    q: 'Verrò seguito/a dai personal trainer in sala pesi?',
    a: "Di più! Con la formula I Love My Trainer acquisti direttamente le lezioni individuali, a partire da 65€/mese, con un Personal Trainer che si dedicherà unicamente a te.",
  },
  {
    q: 'Posso acquistare online gli abbonamenti?',
    a: 'Sì, accedendo alla sezione degli abbonamenti online puoi iscriverti scegliendo la tipologia di abbonamento desiderato.',
  },
];

const TESTIMONIANZE = [
  {
    quote:
      'Ho frequentato questa palestra per sei mesi con un personal trainer e mi sono trovata molto bene. Ho partecipato anche ai corsi organizzati durante la settimana, in particolare Pilates Barre con Luca, e sono rimasta molto soddisfatta.',
    author: 'Elnaz Yousefi',
  },
  {
    quote:
      "Dopo svariate esperienze in altre palestre l'unica cosa che mi era rimasta era la frustrazione di non aver ottenuto risultati. Ho dovuto ricredermi: sono stata ascoltata e guidata verso i miei obiettivi, oggi sono seguita a 360 gradi da tutto il personale.",
    author: 'Francesca Amadei',
  },
  {
    quote:
      'Soluzioni di allenamento variegate, dal classico abbonamento in sala pesi a lezioni di Pilates, yoga, metabolico. Presente anche il Pilates Reformer per completare un allenamento a 360 gradi. Insegnanti tutti preparati e alla mano.',
    author: 'Giorgia Armagno',
  },
];

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 4);
---

<BaseLayout
  title="Passion Fitness | Palestre Roma"
  description="Passion Fitness | Palestre Roma | Passion Fitness Tuscolana"
>
  <Hero
    title="PASSION FITNESS"
    video="/videos/hero-provvisorio.mp4"
    image="/images/uploads/2024/11/MRZ08075.jpeg"
  >
    <p>La palestra più grande delle zone Tuscolana, Cinecittà, Don Bosco e San Policarpo.<br />Un luogo dove persone diverse, con obiettivi unici, trovano il proprio percorso ideale per sentirsi meglio, insieme.</p>
    <div class="hero-ctas">
      <Button href={PROVA_URL} variant="dark-red">Prova Passion Fitness</Button>
      <Button href="/orari-corsi/" variant="ghost-dark">Scopri i Corsi</Button>
    </div>
  </Hero>

  <section class="quicklinks-section">
    <div class="quicklinks">
      {QUICKLINKS.map((item) => (
        <article class="quicklinks__card">
          <div class="quicklinks__bg" style={`background-image: url(${item.image})`}></div>
          <div class="quicklinks__overlay"></div>
          <div class="quicklinks__content">
            <div class="quicklinks__icon" set:html={QUICKLINK_ICONS[item.icon]} />
            <h3>{item.title}</h3>
            <p class="quicklinks__body">{item.body}</p>
            <a class="quicklinks__cta" href={item.href}>{item.cta}</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="programmi-section" aria-label="Programmi Passion Fitness">
    <svg class="programmi-connectors" aria-hidden="true" preserveAspectRatio="none">
      <path class="programmi-connectors__path" data-from="badge" data-to="sala-pesi"></path>
      <path class="programmi-connectors__path" data-from="sala-pesi" data-to="corsi-fitness"></path>
      <path class="programmi-connectors__path" data-from="corsi-fitness" data-to="i-love-my-trainer"></path>
      <path class="programmi-connectors__path" data-from="i-love-my-trainer" data-to="pilates-reformer"></path>
    </svg>
    <div class="container programmi-split">
      <span class="programmi-split__badge" id="badge">programmi</span>
      <nav class="programmi-split__nav" aria-label="Vai al programma">
        {PROGRAMMI.map((p) => (
          <a class="programmi-split__nav-link" href={`#${p.id}`}>{p.title}</a>
        ))}
      </nav>
    </div>
    <div class="programmi">
      {PROGRAMMI.map((p) => (
        <article class="programma" id={p.id}>
          <div class="programma__media">
            <video src={p.video} autoplay muted loop playsinline></video>
          </div>
          <div class="programma__copy">
            <div class="programma__text">
              <h3>{p.title}</h3>
              <p>{p.body}</p>
              <Button href={p.href} variant="white">{p.cta}</Button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script>
    function initProgrammiConnectors() {
      const section = document.querySelector('.programmi-section');
      const svg = document.querySelector('.programmi-connectors');
      if (!section || !svg) return;

      const paths = svg.querySelectorAll('.programmi-connectors__path');
      const radius = 18;

      function resolveEl(id) {
        if (id === 'badge') return document.getElementById('badge');
        const article = document.getElementById(id);
        return article ? article.querySelector('.programma__text') : null;
      }

      function update() {
        const sectionRect = section.getBoundingClientRect();
        svg.setAttribute('width', sectionRect.width);
        svg.setAttribute('height', sectionRect.height);
        svg.setAttribute('viewBox', `0 0 ${sectionRect.width} ${sectionRect.height}`);

        paths.forEach((path) => {
          const fromEl = resolveEl(path.dataset.from);
          const toEl = resolveEl(path.dataset.to);
          const toArticle = document.getElementById(path.dataset.to);
          if (!fromEl || !toEl || !toArticle) return;

          const fromRect = fromEl.getBoundingClientRect();
          const toRect = toEl.getBoundingClientRect();
          const boundaryRect = toArticle.getBoundingClientRect();

          const x1 = fromRect.left + fromRect.width / 2 - sectionRect.left;
          const y1 = fromRect.bottom - sectionRect.top;
          const x2 = toRect.left + toRect.width / 2 - sectionRect.left;
          const y2 = toRect.top - sectionRect.top;
          const yMid = boundaryRect.top - sectionRect.top;

          const dir = x2 >= x1 ? 1 : -1;
          const r = Math.max(0, Math.min(radius, Math.abs(yMid - y1), Math.abs(y2 - yMid), Math.abs(x2 - x1) / 2));

          const d = `M ${x1} ${y1} V ${yMid - r} Q ${x1} ${yMid} ${x1 + r * dir} ${yMid} H ${x2 - r * dir} Q ${x2} ${yMid} ${x2} ${yMid + r} V ${y2}`;
          path.setAttribute('d', d);
        });
      }

      update();
      window.addEventListener('resize', update);
      window.addEventListener('load', update);

      if (window.ResizeObserver) {
        const observer = new ResizeObserver(() => update());
        observer.observe(document.body);
      } else {
        setTimeout(update, 300);
        setTimeout(update, 1000);
      }
    }

    initProgrammiConnectors();
  </script>

  <Section tone="blush">
    <div class="perche">
      <div class="perche__copy">
        <h2>Perché scegliere noi?</h2>
        <p>Con 30 anni di esperienza e gli insegnamenti appresi dai nostri errori, abbiamo imparato a mettere al centro la persona prima dell'allenamento. Ti dedichiamo tutta l'attenzione che meriti, allenandoci al tuo fianco finché non acquisirai piena sicurezza in te.</p>
      </div>
      <div class="faq">
        {FAQ.map((item) => (
          <details class="faq__item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </Section>

  <Section tone="red">
    <div class="stats">
      <div class="stat">
        <span class="stat__num">30+</span>
        <span class="stat__label">Anni nel settore</span>
      </div>
      <div class="stat">
        <span class="stat__num">2000</span>
        <span class="stat__label">m² dedicati al fitness</span>
      </div>
      <div class="stat">
        <span class="stat__num">1000</span>
        <span class="stat__label">mq di sala pesi</span>
      </div>
      <div class="stat">
        <span class="stat__num">2+2</span>
        <span class="stat__label">Sale fitness e studi reformer</span>
      </div>
    </div>
  </Section>

  <Section tone="light">
    <h2>Cosa dicono di noi</h2>
    <div class="testimonials">
      {TESTIMONIANZE.map((t) => (
        <figure class="testimonial">
          <blockquote>"{t.quote}"</blockquote>
          <figcaption>{t.author} <span>— Recensione Google</span></figcaption>
        </figure>
      ))}
    </div>
  </Section>

  <Section tone="blush">
    <div class="section-head">
      <h2>Il blog di Passion</h2>
      <a class="quicklinks__link" href="/blog/">Scopri tutti gli articoli →</a>
    </div>
    <PostList posts={latestPosts} />
  </Section>

  <CTA
    heading="Pronto a iniziare?"
    buttonLabel="Prova Passion Fitness"
    buttonHref={PROVA_URL}
    tone="dark"
  />
</BaseLayout>

<style>
  .hero-ctas {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
    margin-top: var(--space-2xs);
  }

  .quicklinks-section {
    height: 100vh;
    border-top: 6px solid var(--color-red);
  }
  .quicklinks {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    height: 100%;
  }
  .quicklinks__card {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .quicklinks__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }
  .quicklinks__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    transition: background-color 0.3s ease;
  }
  .quicklinks__card:hover .quicklinks__overlay {
    background: var(--accent);
  }
  .quicklinks__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-2xs);
    padding: var(--space-lg) var(--space-md);
    max-width: 26rem;
  }
  .quicklinks__icon {
    width: 3.25rem;
    height: 3.25rem;
    color: var(--color-white);
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity 0.25s ease, max-height 0.25s ease, margin-bottom 0.25s ease;
  }
  .quicklinks__card:hover .quicklinks__icon {
    opacity: 1;
    max-height: 4rem;
    margin-bottom: var(--space-2xs);
  }
  .quicklinks__icon svg {
    width: 100%;
    height: 100%;
  }
  .quicklinks__content h3 {
    color: var(--color-white);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
  }
  .quicklinks__body {
    color: var(--text-on-dark-muted);
    font-size: 0.95rem;
    line-height: 1.5;
    opacity: 0;
    max-height: 0;
    margin: 0;
    overflow: hidden;
    transition: opacity 0.25s ease, max-height 0.25s ease, margin-block 0.25s ease;
  }
  .quicklinks__card:hover .quicklinks__body {
    opacity: 1;
    max-height: 12rem;
    margin-block: var(--space-2xs);
  }
  .quicklinks__cta {
    display: inline-block;
    width: fit-content;
    margin-top: var(--space-sm);
    padding: 0.85rem 1.5rem;
    background: var(--color-white);
    color: var(--text-on-light);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 8px;
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .quicklinks__cta:hover {
    background: var(--color-black);
    color: var(--color-white);
  }
  .quicklinks__link {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-red);
  }
  @media (max-width: 760px) {
    .quicklinks-section {
      height: auto;
    }
    .quicklinks {
      grid-template-columns: 1fr;
    }
    .quicklinks__card {
      min-height: 24rem;
    }
  }

  .programmi-section {
    position: relative;
    background: var(--accent);
  }
  .programmi-connectors {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .programmi-connectors__path {
    fill: none;
    stroke: var(--color-white);
    stroke-width: 2px;
  }
  .programmi-split {
    position: relative;
    z-index: 5;
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-sm);
    margin-bottom: var(--space-md);
  }
  .programmi-split__badge {
    display: inline-block;
    background: var(--color-red);
    border: 2px solid var(--color-white);
    color: var(--color-white);
    font-family: var(--font-display);
    text-transform: lowercase;
    font-size: clamp(2rem, 4.2vw, 3.2rem);
    line-height: 1;
    padding: 0.15em 0.4em;
    border-radius: 12px;
    transform: translateY(-50%);
  }
  .programmi-split__nav {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: var(--space-xs) var(--space-sm);
  }
  .programmi-split__nav-link {
    display: inline-block;
    background: var(--color-red);
    color: var(--color-white);
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.5em 0.9em;
    border-radius: 8px;
    transform: translateY(-50%);
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .programmi-split__nav-link:hover {
    background: var(--bg-light-soft);
    color: var(--color-red);
  }
  .programmi {
    display: flex;
    flex-direction: column;
  }
  .programma {
    display: grid;
    grid-template-columns: 5fr 3fr;
    height: 100vh;
  }
  .programma:nth-child(even) {
    grid-template-columns: 3fr 5fr;
  }
  .programma:nth-child(even) .programma__media {
    order: 2;
  }
  .programma__media {
    position: relative;
    background: var(--accent);
    overflow: hidden;
    border-radius: 12px;
    padding-block: var(--space-lg);
  }
  .programma__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
  }
  .programma__copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-md) clamp(1.25rem, 4vw, 2.5rem);
    overflow-y: auto;
  }
  .programma__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2xs);
    border: 2px solid var(--color-white);
    border-radius: 12px;
    padding: var(--space-md);
  }
  .programma__text :global(.button) {
    margin-top: var(--space-xs);
  }
  .programma__text h3 {
    color: var(--color-white);
    font-size: clamp(2.2rem, 4.5vw, 3.8rem);
  }
  .programma__text p {
    color: var(--color-white);
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    margin-top: var(--space-2xs);
  }
  @media (max-width: 760px) {
    .programma,
    .programma:nth-child(even) {
      grid-template-columns: 1fr;
      grid-template-rows: 5fr 3fr;
    }
    .programma:nth-child(even) .programma__media {
      order: 0;
    }
  }

  .perche {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }
  .perche__copy p {
    margin-top: var(--space-sm);
    color: var(--text-on-light-muted);
  }
  .faq {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
  .faq__item {
    background: var(--color-white);
    border: 1px solid var(--border-on-light);
    padding: var(--space-sm);
  }
  .faq__item summary {
    cursor: pointer;
    font-weight: 700;
  }
  .faq__item p {
    margin-top: var(--space-2xs);
    color: var(--text-on-light-muted);
  }
  @media (max-width: 760px) {
    .perche {
      grid-template-columns: 1fr;
    }
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: var(--space-md);
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }
  .stat__num {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3rem);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat__label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.9;
  }

  .testimonials {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-md);
    margin-top: var(--space-md);
  }
  .testimonial {
    margin: 0;
    padding: var(--space-sm);
    border: 1px solid var(--border-on-light);
    border-top: 3px solid var(--color-red);
  }
  .testimonial blockquote {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .testimonial figcaption {
    margin-top: var(--space-sm);
    font-weight: 700;
