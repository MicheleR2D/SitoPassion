---
interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  video?: string;
}

const { title, description, href, image, video } = Astro.props;
---

<article class="service-card">
  <a href={href} class="service-card__media">
    {video ? (
      <video src={video} autoplay muted loop playsinline></video>
    ) : image ? (
      <img src={image} alt="" />
    ) : (
      <span class="service-card__placeholder">Foto in arrivo</span>
    )}
  </a>
  <div class="service-card__body">
    <h3><a href={href}>{title}</a></h3>
    <p>{description}</p>
    <a class="service-card__link" href={href}>Scopri <span aria-hidden="true">→</span></a>
  </div>
</article>

<style>
  .service-card {
    background: var(--bg-dark-surface);
    border: 1px solid var(--border-on-dark);
    display: flex;
    flex-direction: column;
    min-height: 22rem;
  }
  .service-card__media {
    display: block;
    height: 12rem;
    background: var(--color-black);
    overflow: hidden;
  }
  .service-card__media img,
  .service-card__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .service-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-on-dark-muted);
    background: repeating-linear-gradient(135deg, #241f1f 0 14px, #1b1717 14px 28px);
  }
  .service-card__body {
    padding: var(--space-sm) var(--space-sm) var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    flex: 1;
  }
  .service-card__body h3 {
    color: var(--text-on-dark);
    font-size: 1.4rem;
  }
  .service-card__body p {
    font-size: 0.88rem;
    color: var(--text-on-dark-muted);
    line-height: 1.5;
    flex: 1;
  }
  .service-card__link {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-red);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border-bottom: 1px solid transparent;
  }
  .service-card__link:hover {
    border-color: var(--color-red);
  }
</style>
