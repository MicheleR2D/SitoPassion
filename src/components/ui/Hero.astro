---
interface Props {
  title: string;
  image?: string;
  video?: string;
  videoEndBuffer?: number;
  eyebrow?: string;
}

const { title, image, video, videoEndBuffer = 3, eyebrow } = Astro.props;
---

<div class="hero">
  {video && (
    <div class="hero-media">
      <video
        class="hero-media__video"
        src={video}
        poster={image}
        data-end-buffer={videoEndBuffer}
        autoplay
        muted
        playsinline
      />
    </div>
  )}
  {!video && image && (
    <div class="hero-photo">
      <img src={image} alt="" />
    </div>
  )}
  <div class="container hero-inner" class:list={{ "hero-inner--with-photo": image || video }}>
    <div class="hero-copy">
      <div class="hero-title-group">
        {eyebrow && <p class="eyebrow hero-eyebrow">{eyebrow}</p>}
        <h1>{title}</h1>
      </div>
      <div class="hero-extra">
        <slot />
      </div>
    </div>
  </div>
</div>

{video && (
  <script>
    document.querySelectorAll('.hero-media video').forEach((videoEl) => {
      const endBuffer = Number(videoEl.dataset.endBuffer ?? '3');
      videoEl.addEventListener('timeupdate', () => {
        if (videoEl.duration && videoEl.currentTime >= videoEl.duration - endBuffer) {
          videoEl.currentTime = 0;
        }
      });
    });
  </script>
)}

<style>
  .hero {
    position: relative;
    background: var(--bg-dark);
    overflow: hidden;
    margin-top: calc(-1 * var(--header-height));
    height: 100vh;
  }
  .hero:not(:has(.hero-photo, .hero-media)) {
    height: auto;
  }
  .hero:has(.hero-media) {
    display: grid;
    grid-template-columns: 2fr 1fr;
  }
  .hero:has(.hero-media) .hero-inner {
    grid-column: 2;
    background: var(--accent);
    border-left: 6px solid var(--color-black);
  }
  .hero:has(.hero-media) .hero-eyebrow {
    color: var(--color-white);
  }
  .hero:has(.hero-media) .hero-extra {
    color: var(--color-white);
  }
  .hero:has(.hero-media) h1 {
    color: var(--color-black);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
  }
  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding-block: clamp(1.5rem, 4vw, 3rem);
  }
  .hero-inner--with-photo .hero-copy {
    max-width: 34rem;
  }
  .hero-eyebrow {
    color: var(--color-red);
  }
  .hero h1 {
    color: var(--text-on-dark);
  }
  .hero-extra {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    color: var(--text-on-dark-muted);
  }
  .hero-extra p {
    line-height: 1.9;
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    left: 45%;
    background: var(--color-black);
    clip-path: polygon(12% 0, 100% 0, 100% 100%, 0% 100%);
    overflow: hidden;
  }
  .hero-photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(200deg, rgba(227, 3, 45, 0.45) 0%, rgba(0, 0, 0, 0.1) 45%, transparent 70%);
  }

  .hero-media {
    position: relative;
    height: 100%;
    background: var(--color-black);
    overflow: hidden;
  }
  .hero-media__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }

  @media (max-width: 860px) {
    .hero:has(.hero-photo) {
      height: auto;
    }
    .hero-photo {
      position: relative;
      left: 0;
      height: 18rem;
      clip-path: none;
    }
    .hero:has(.hero-photo) .hero-inner--with-photo {
      padding-top: 0;
    }
    .hero-inner--with-photo .hero-copy {
      max-width: none;
    }

    .hero:has(.hero-media) {
      grid-template-columns: 1fr;
      grid-template-rows: 2fr 1fr;
    }
    .hero:has(.hero-media) .hero-inner {
      grid-column: 1;
      border-left: none;
      border-top: 6px solid var(--color-black);
      padding-top: var(--space-sm);
    }
    .hero:has(.hero-media) .hero-copy {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-sm);
      padding-block: 0;
    }
    .hero:has(.hero-media) .hero-title-group {
      flex: 1 1 40%;
      min-width: 9rem;
      display: flex;
      flex-direction: column;
      gap: var(--space-3xs);
    }
    .hero:has(.hero-media) .hero-title-group h1 {
      font-size: clamp(1.5rem, 8vw, 2.1rem);
      line-height: 1.05;
    }
    .hero:has(.hero-media) .hero-eyebrow {
      font-size: 0.62rem;
    }
    .hero:has(.hero-media) .hero-extra {
      flex: 1 1 52%;
      min-width: 10rem;
      gap: var(--space-2xs);
    }
    .hero:has(.hero-media) .hero-extra :global(p) {
      font-size: 0.78rem;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .hero:has(.hero-media) :global(.hero-ctas) {
      gap: var(--space-2xs);
    }
    .hero:has(.hero-media) :global(.hero-ctas) :global(.button) {
      font-size: 0.62rem;
      padding: 0.55rem 0.8rem;
      border-width: 2px;
    }
  }
</style>
