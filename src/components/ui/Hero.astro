---
interface Props {
  title: string;
  image?: string;
  eyebrow?: string;
}

const { title, image, eyebrow } = Astro.props;
---

<div class="hero">
  {image && (
    <div class="hero-photo">
      <img src={image} alt="" />
    </div>
  )}
  <div class="container hero-inner" class:list={{ "hero-inner--with-photo": image }}>
    <div class="hero-copy">
      {eyebrow && <p class="eyebrow hero-eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <div class="hero-extra">
        <slot />
      </div>
    </div>
  </div>
</div>

<style>
  .hero {
    position: relative;
    background: var(--bg-dark);
    overflow: hidden;
    margin-top: calc(-1 * var(--header-height));
    height: clamp(28rem, 100vh, 40rem);
  }
  .hero:not(:has(.hero-photo)) {
    height: auto;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
  }
  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding-block: clamp(1.5rem, 4vw, 3rem);
  }
  .hero-inner--with-photo .hero-copy {
    max-width: 34rem;
  }
  .hero-eyebrow {
    color: var(--color-red);
  }
  .hero h1 {
    color: var(--text-on-dark);
  }
  .hero-extra {
    color: var(--text-on-dark-muted);
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    left: 45%;
    background: var(--color-black);
    clip-path: polygon(12% 0, 100% 0, 100% 100%, 0% 100%);
    overflow: hidden;
  }
  .hero-photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(200deg, rgba(227, 3, 45, 0.45) 0%, rgba(0, 0, 0, 0.1) 45%, transparent 70%);
  }

  @media (max-width: 860px) {
    .hero {
      height: auto;
    }
    .hero-photo {
      position: relative;
      left: 0;
      height: 18rem;
      clip-path: none;
    }
    .hero-inner--with-photo {
      padding-top: 0;
    }
    .hero-inner--with-photo .hero-copy {
      max-width: none;
    }
  }
</style>
