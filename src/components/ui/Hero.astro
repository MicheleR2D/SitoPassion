---
interface Props {
  title: string;
  image?: string;
}

const { title, image } = Astro.props;
---

<div class="hero">
  {image && <img src={image} alt="" class="hero__image" />}
  <h1 class="hero__title">{title}</h1>
</div>

<style>
  .hero {
    position: relative;
  }
  .hero__image {
    width: 100%;
    object-fit: cover;
  }
</style>
