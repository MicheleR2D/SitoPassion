---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<a href={href} class="button">
  <slot />
</a>

<style>
  .button {
    display: inline-block;
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--color-primary);
    text-decoration: none;
  }
</style>
