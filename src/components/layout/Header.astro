---
import Nav from './Nav.astro';

// Nessun file "logo*" tra quelli migrati e' affidabile come logo definitivo (13 candidati
// trovati, tra bozze del tema demo e test) - wordmark testuale provvisorio, facile da
// sostituire con un <img> quando il logo reale sara' confermato.
---

<div class="announce">
  <div class="container">Tuscolana · Cinecittà · Don Bosco · San Policarpo — aperti dalle 5:00 alle 24:00, 365 giorni l'anno</div>
</div>

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="wordmark">PASSION<span>FITNESS</span></a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" />
    <label for="nav-toggle" class="nav-toggle" aria-label="Apri il menu">
      <span></span><span></span><span></span>
    </label>

    <div class="nav-panel">
      <Nav />
    </div>

    <a class="prova-gratis" href="https://automazione.n8ndevelop.it/form/8ce36c5e-0cc4-4813-9a0f-2da2a7605fb0?source=SitoWeb&medium=Btn_Header">
      Prova Gratis <span aria-hidden="true">→</span>
    </a>
  </div>
</header>

<style>
  .announce {
    background: var(--color-red);
    color: var(--color-white);
  }
  .announce .container {
    padding-block: 0.5rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-align: center;
  }

  .site-header {
    background: var(--bg-dark);
    border-bottom: 1px solid var(--border-on-dark);
    position: relative;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-block: var(--space-xs);
  }

  .wordmark {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    color: var(--text-on-dark);
    white-space: nowrap;
  }
  .wordmark span {
    color: var(--color-red);
  }

  .prova-gratis {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-red);
    color: var(--color-white);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.75rem 1.25rem;
    white-space: nowrap;
    transition: background-color 0.15s ease;
  }
  .prova-gratis:hover {
    background: var(--color-red-hover);
  }

  .nav-toggle-input {
    display: none;
  }
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2rem;
    height: 2rem;
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    height: 2px;
    background: var(--text-on-dark);
  }

  @media (max-width: 900px) {
    .site-header__inner {
      flex-wrap: wrap;
    }
    .prova-gratis {
      display: none;
    }
    .nav-toggle {
      display: flex;
      order: 2;
    }
    .nav-panel {
      order: 3;
      flex-basis: 100%;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.2s ease;
    }
    .nav-toggle-input:checked ~ .nav-panel {
      max-height: 30rem;
    }
    .nav-panel :global(.site-nav > ul) {
      flex-direction: column;
      gap: 0;
      padding-block: var(--space-2xs) var(--space-sm);
    }
    .nav-panel :global(.site-nav__dropdown) {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      border: none;
      background: transparent;
      padding-left: var(--space-sm);
    }
  }
</style>
