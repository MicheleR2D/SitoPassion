---
import Nav from './Nav.astro';
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand">
      <img src="/images/logo-passion-mark.png" alt="Passion Fitness Club" width="1409" height="592" />
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" />
    <label for="nav-toggle" class="nav-toggle" aria-label="Apri il menu">
      <span></span><span></span><span></span>
    </label>

    <div class="nav-panel">
      <Nav />
    </div>

    <a class="prova-gratis" href="https://automazione.n8ndevelop.it/form/8ce36c5e-0cc4-4813-9a0f-2da2a7605fb0?source=SitoWeb&medium=Btn_Header">
      Prova Gratis <span aria-hidden="true">→</span>
    </a>
  </div>
</header>

<script>
  const header = document.querySelector('.site-header');
  const updateHeaderState = () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 40);
  };
  updateHeaderState();
  window.addEventListener('scroll', updateHeaderState, { passive: true });
</script>

<style>
  .site-header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background-color 0.25s ease, border-color 0.25s ease;
  }
  .site-header.is-scrolled,
  .site-header:has(.nav-toggle-input:checked) {
    background: var(--bg-dark);
    border-bottom-color: var(--border-on-dark);
  }
  .site-header.is-scrolled .prova-gratis {
    color: var(--color-red);
    border-color: var(--color-red);
  }
  .site-header.is-scrolled .prova-gratis:hover {
    background: var(--color-red);
    color: var(--color-white);
    border-color: var(--color-red-hover);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: var(--space-md);
    padding-block: var(--space-xs);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }
  .brand img {
    height: 2.75rem;
    width: auto;
  }

  .prova-gratis {
    position: absolute;
    top: 50%;
    left: calc(66.6667% + clamp(1.25rem, 4vw, 2.5rem));
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    color: var(--color-white);
    border: 3px solid var(--color-white);
    border-radius: 10px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.75rem 1.25rem;
    white-space: nowrap;
    transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .prova-gratis:hover {
    background: var(--color-white);
    color: var(--text-on-light);
    border-color: var(--color-white);
  }

  .nav-toggle-input {
    display: none;
  }
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2rem;
    height: 2rem;
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    height: 2px;
    background: var(--text-on-dark);
  }

  @media (max-width: 900px) {
    .site-header__inner {
      flex-wrap: wrap;
    }
    .prova-gratis {
      display: none;
    }
    .nav-toggle {
      display: flex;
      order: 2;
    }
    .nav-panel {
      order: 3;
      flex-basis: 100%;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.2s ease;
    }
    .nav-toggle-input:checked ~ .nav-panel {
      max-height: calc(100vh - var(--header-height));
      overflow-y: auto;
    }
    .nav-panel :global(.site-nav > ul) {
      flex-direction: column;
      gap: 0;
      padding-block: var(--space-2xs) var(--space-sm);
    }
    .nav-panel :global(.site-nav__dropdown) {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      border: none;
      background: transparent;
      padding-left: var(--space-sm);
    }
  }
</style>
