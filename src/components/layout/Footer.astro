---
import { getEntry } from 'astro:content';

const footer = await getEntry('footerSettings', 'footer');
const site = await getEntry('siteSettings', 'site');
const data = footer?.data;
const socials = site?.data.socials ?? {};
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="wordmark">PASSION<span>FITNESS</span></a>
        {data?.address && <p>{data.address}</p>}
      </div>

      <div class="footer-col">
        <h4 class="eyebrow">Palestra</h4>
        <ul>
          <li><a href="/palestra/sala-pesi/">Sala Pesi</a></li>
          <li><a href="/palestra/corsi-fitness/">Corsi Fitness</a></li>
          <li><a href="/crossfit/">Crossfit Acquedotti</a></li>
          <li><a href="/orari-corsi/">Orari Corsi</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="eyebrow">Servizi</h4>
        <ul>
          <li><a href="/i-love-my-trainer/">Personal Training</a></li>
          <li><a href="/pilates-reformer/">Pilates Reformer</a></li>
          <li><a href="/hyrox/">Hyrox</a></li>
          <li><a href="/abbonamenti/">Abbonamenti</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="eyebrow">Contatti</h4>
        <ul>
          {data?.phone && <li><a href={`tel:+39${data.phone}`}>{data.phone}</a></li>}
          {data?.email && <li><a href={`mailto:${data.email}`}>{data.email}</a></li>}
          <li><a href="/porta-un-amico/">Porta un Amico</a></li>
        </ul>
        {Object.keys(socials).length > 0 && (
          <ul class="footer-socials">
            {Object.entries(socials).map(([name, url]) => (
              <li><a href={url}>{name}</a></li>
            ))}
          </ul>
        )}
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} Passion Fitness — Palestra Roma Tuscolana</span>
      <span>
        <a href="/informativa-privacy/">Privacy</a> · <a href="/informativa-estesa-sullutilizzo-dei-cookie/">Cookie</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-dark);
    color: var(--text-on-dark);
    padding-block: var(--space-lg) var(--space-md);
  }

  .wordmark {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.2rem;
    color: var(--text-on-dark);
  }
  .wordmark span {
    color: var(--color-red);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: var(--space-md);
    padding-bottom: var(--space-lg);
  }
  .footer-brand p {
    margin-top: var(--space-xs);
    font-size: 0.85rem;
    color: var(--text-on-dark-muted);
    max-width: 18rem;
    line-height: 1.5;
  }
  .footer-col h4 {
    color: var(--text-on-dark-muted);
    margin-bottom: var(--space-xs);
  }
  .footer-col ul,
  .footer-socials {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    font-size: 0.88rem;
  }
  .footer-col a:hover,
  .footer-socials a:hover {
    color: var(--color-red);
  }
  .footer-socials {
    flex-direction: row;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
    text-transform: uppercase;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .footer-bottom {
    border-top: 1px solid var(--border-on-dark);
    padding-top: var(--space-sm);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    font-size: 0.75rem;
    color: var(--text-on-dark-muted);
  }
  .footer-bottom a:hover {
    color: var(--color-red);
  }

  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
