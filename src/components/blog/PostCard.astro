---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, slug, excerpt, coverImage, categories, publishedAt } = post.data;
---

<article class="post-card">
  <a href={`/${slug}/`} class="post-card__media">
    {coverImage ? <img src={coverImage} alt="" /> : <span class="post-card__placeholder" />}
  </a>
  <div class="post-card__body">
    {categories[0] && <p class="eyebrow post-card__category">{categories[0]}</p>}
    <h3><a href={`/${slug}/`}>{title}</a></h3>
    {excerpt && <p class="post-card__excerpt">{excerpt}</p>}
    <time datetime={publishedAt.toISOString()}>{publishedAt.toLocaleDateString('it-IT')}</time>
  </div>
</article>

<style>
  .post-card {
    background: var(--color-white);
    border: 1px solid var(--border-on-light);
    display: flex;
    flex-direction: column;
  }
  .post-card__media {
    display: block;
    aspect-ratio: 16 / 10;
    background: var(--bg-light-soft);
    overflow: hidden;
  }
  .post-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.2s ease;
  }
  .post-card:hover .post-card__media img {
    transform: scale(1.04);
  }
  .post-card__placeholder {
    display: block;
    width: 100%;
    height: 100%;
  }
  .post-card__body {
    padding: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }
  .post-card__category {
    color: var(--color-red);
  }
  .post-card__body h3 {
    font-size: 1.15rem;
    line-height: 1.1;
    margin-top: 0.2rem;
  }
  .post-card__body h3 a:hover {
    color: var(--color-red);
  }
  .post-card__excerpt {
    font-size: 0.85rem;
    color: var(--text-on-light-muted);
    line-height: 1.5;
    margin-top: 0.3rem;
  }
  .post-card time {
    margin-top: var(--space-2xs);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-on-light-muted);
  }
</style>
